# Backend environment variables (copy to backend/.env)
PORT=4000
MONGO_URI=mongodb://localhost:27017/aoto-chat
# Your Gemini / Generative Language API key
GEMINI_API_KEY=
# Optional: custom Gemini base URL and model
GEMINI_API_URL=
GEMINI_MODEL=text-bison-001

# LibreTranslate fallback
TRANSLATE_URL=https://translate.argosopentech.com/translate

# Force local heuristics (true/false)
FORCE_LOCAL_AI=false

# Circuit-breaker timeout for Gemini failures (ms)
GEMINI_COOLDOWN_MS=300000
